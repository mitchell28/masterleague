		"db:init-teams": "vite-node src/lib/scripts/init-teams.ts",
		"db:seed-fixtures": "vite-node src/lib/scripts/seed-fixtures.ts",
		"db:setup-organization": "vite-node src/lib/scripts/setup-default-organization.ts",
		"knip": "knip",
		"dev:trigger": "trigger dev",
		"deploy:trigger": "trigger deploy"
	},
